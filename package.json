{
  "name": "vite-nitro-vue3",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prepare": "nitro prepare",
    "serve": "cross-env PORT=18412 nitro dev",
    "preview": "cross-env PORT=8412 HOST=127.0.0.1 node .output/server/index.mjs",
    "build:client": "vite build",
    "build:server": "nitro build",
    "build": "npm run build:client && npm run build:server",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "preview:vue": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ts": "vue-tsc --noEmit",
    "lint:css": "stylelint '**/*.{css,scss}' --fix",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@lincy/async-validation": "catalog:prod",
    "@lincy/utils": "catalog:prod",
    "@tanstack/vue-query": "catalog:prod",
    "@tato30/vue-pdf": "catalog:prod",
    "@unhead/vue": "catalog:prod",
    "@vueuse/core": "catalog:prod",
    "@vueuse/router": "catalog:prod",
    "alova": "catalog:prod",
    "better-sqlite3": "catalog:prod",
    "default-passive-events": "catalog:prod",
    "destr": "catalog:prod",
    "element-plus": "catalog:prod",
    "highlight.js": "catalog:prod",
    "lodash": "catalog:prod",
    "markdown-it-link-attributes": "catalog:prod",
    "md-editor-v3": "catalog:prod",
    "mitt": "catalog:prod",
    "nitropack": "catalog:prod",
    "ofetch": "catalog:prod",
    "pinia": "catalog:prod",
    "qs": "catalog:prod",
    "store2": "catalog:prod",
    "twig": "catalog:prod",
    "vue": "catalog:prod",
    "vue-router": "catalog:prod"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "catalog:icons",
    "@iconify-json/carbon": "catalog:icons",
    "@iconify-json/fad": "catalog:icons",
    "@iconify-json/svg-spinners": "catalog:icons",
    "@iconify-json/vscode-icons": "catalog:icons",
    "@lincy/eslint-config": "catalog:lint",
    "@lincy/stylelint-config": "catalog:lint",
    "@lincy/unocss-base-config": "catalog:dev",
    "@types/markdown-it-link-attributes": "catalog:types",
    "@types/mockjs": "catalog:types",
    "@types/node": "catalog:types",
    "@types/polyfill-library": "catalog:types",
    "@types/qs": "catalog:types",
    "@types/twig": "catalog:types",
    "@unocss/eslint-plugin": "catalog:lint",
    "@vitejs/plugin-vue": "catalog:dev",
    "@vitejs/plugin-vue-jsx": "catalog:dev",
    "@vue-macros/define-props": "catalog:dev",
    "@vue-macros/define-props-refs": "catalog:dev",
    "@vue-macros/reactivity-transform": "catalog:dev",
    "@vue-macros/volar": "catalog:dev",
    "cross-env": "catalog:dev",
    "eslint": "catalog:lint",
    "eslint-plugin-format": "catalog:lint",
    "jiti": "catalog:dev",
    "lint-staged": "catalog:dev",
    "mockjs": "catalog:dev",
    "polyfill-library": "catalog:dev",
    "sass-embedded": "catalog:dev",
    "stylelint": "catalog:lint",
    "typescript": "catalog:dev",
    "unocss": "catalog:dev",
    "unplugin-auto-import": "catalog:dev",
    "unplugin-icons": "catalog:dev",
    "unplugin-vue-components": "catalog:dev",
    "vite": "catalog:dev",
    "vite-plugin-inspect": "catalog:dev",
    "vite-plugin-progress": "catalog:dev",
    "vue-macros": "catalog:dev",
    "vue-tsc": "catalog:dev"
  },
  "resolutions": {
    "h3": "1.15.4"
  },
  "simple-git-hooks[-del]": {
    "pre-commit": "npm run lint-staged"
  },
  "lint-staged[-del]": {
    "*.{[jt]s?(x),vue,md}": [
      "eslint --fix"
    ],
    "*.{css,scss}": "stylelint --fix --allow-empty-input"
  }
}
